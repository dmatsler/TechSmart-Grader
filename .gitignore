# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# Secrets — API keys, TechSmart credentials
.env

# Locally cached TechSmart curriculum (requirements + starter + solution code)
# Scraped from platform.techsmart.codes — their copyrighted material
context_cache_*.json

# Hand-curated TechSmart solution + starter code in markdown form
# (source-of-truth that feeds context_cache_*.json via load_unit_from_markdown.py)
# Same copyright reasoning as the cache itself — TechSmart's material.
unit_*_solutions.md
unit_*_starter_code.md
unit_*_starters.md

# User-specific state — class IDs, saved run configs, active unit
gradebook_url*.json
saved_runs*.json
active_*.json

# Grading reports — student names + grades (FERPA)
# Default output is ~/Desktop/techsmart_grades but in case you ever
# point the GUI's output folder inside the repo
grades_*.csv
grades_*.html
grades_detail_*.csv
DO_NOT_SHARE_*.json
techsmart_grades/

# Editor / OS noise
.vscode/
.idea/
.DS_Store
Old Version/
